# --- Capital.com auth (shared across all symbols) ---
CAPITAL_API_KEY=
IDENTIFIER=
PASSWORD=
MODE=demo

# --- Postgres trade journal (must match docker-compose.yml) ---
DATABASE_URL=postgresql://operator:operator_dev@localhost:5432/trade_journal

# --- Strategy defaults (shared) ---
TIMEFRAME=MINUTE_15
SIZE=1000

# --- Symbols to trade (comma-separated, no spaces required) ---
SYMBOLS=EURUSD,USDJPY,GBPUSD,AUDUSD,USDCAD,USDCHF

# --- Epic per symbol (REQUIRED for every listed symbol) ---
# A missing/blank epic fails fast at startup, so a wrong epic never silently
# trades the wrong instrument. All six verified TRADEABLE on the Capital demo
# via GET /markets?searchTerm=... — the epic equals the symbol for these pairs.
EPIC_EURUSD=EURUSD
EPIC_USDJPY=USDJPY
EPIC_GBPUSD=GBPUSD
EPIC_AUDUSD=AUDUSD
EPIC_USDCAD=USDCAD
EPIC_USDCHF=USDCHF

# --- Optional per-symbol size override (falls back to SIZE, then 1000) ---
# JPY pairs often use a different size semantic; override here if needed.
# SIZE_USDJPY=1000
