# --- Capital.com auth (shared across all symbols) ---
CAPITAL_API_KEY=
IDENTIFIER=
PASSWORD=
MODE=demo

# --- eToro auth (portfolio rebalancer) ---
# ETORO_API_KEY  -> application public key, sent as x-api-key
# ETORO_USER_KEY -> account user key (Settings > Trading > API Key Management), sent as x-user-key
# ETORO_MODE     -> demo | real (real requires I_UNDERSTAND_THIS_IS_REAL_MONEY=YES)
ETORO_MODE=demo
ETORO_API_KEY=
ETORO_USER_KEY=

# --- eToro basket symbol mapping (optional overrides) ---
# Defaults live in src/config.py (_ETORO_DEFAULT_SYMBOL_MAP) and already pick
# the cheapest same-index tickers on eToro: VOO, QQQ, IWM, IEMG, IEFA, TLT,
# GLDM, BTC. Override only for account-specific ticker availability:
# ETORO_TICKER_XAUUSD=IAU

# --- Postgres trade journal (must match docker-compose.yml) ---
DATABASE_URL=postgresql://operator:operator_dev@localhost:5432/trade_journal

# --- Strategy defaults (shared) ---
TIMEFRAME=MINUTE_15
SIZE=1000

# --- Symbols to trade (comma-separated, no spaces required) ---
SYMBOLS=EURUSD,USDJPY,GBPUSD,AUDUSD,USDCAD,USDCHF

# --- Epic per symbol (REQUIRED for every listed symbol) ---
# A missing/blank epic fails fast at startup, so a wrong epic never silently
# trades the wrong instrument. All six verified TRADEABLE on the Capital demo
# via GET /markets?searchTerm=... — the epic equals the symbol for these pairs.
EPIC_EURUSD=EURUSD
EPIC_USDJPY=USDJPY
EPIC_GBPUSD=GBPUSD
EPIC_AUDUSD=AUDUSD
EPIC_USDCAD=USDCAD
EPIC_USDCHF=USDCHF

# --- Optional per-symbol size override (falls back to SIZE, then 1000) ---
# JPY pairs often use a different size semantic; override here if needed.
# SIZE_USDJPY=1000
